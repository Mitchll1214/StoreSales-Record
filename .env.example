# ===== 数据库配置 =====
# 默认使用本地 SQLite（零配置，数据文件存储在 ./data/store_sales.sqlite）
# 如需使用外部 MySQL，取消下方注释并填写你的 MySQL 服务器信息：
# DB_DIALECT=mysql
# DB_HOST=your-mysql-host.com
# DB_PORT=3306
# DB_NAME=store_sales
# DB_USER=root
# DB_PASSWORD=your-password

# ===== JWT 密钥 =====
JWT_SECRET=change-me-to-a-random-string

# ===== 服务端口 =====
PORT=3000

# ===== 数据库配置 =====
# 默认使用本地 SQLite（零配置，数据文件存储在 ./data/store_sales.sqlite）
# 如需使用 MySQL，取消下方注释并填写正确参数：
# DB_DIALECT=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_NAME=store_sales
# DB_USER=root
# DB_PASSWORD=root123
# 也可手动指定数据库类型：DB_DIALECT=sqlite 或 DB_DIALECT=mysql

# ===== JWT 密钥 =====
JWT_SECRET=change-me-to-a-random-string

# ===== 服务端口 =====
PORT=3000

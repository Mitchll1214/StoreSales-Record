<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>销售统计报表 - 门店销售统计系统</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/header', { user }) %>

  <div class="layout-container">
    <div class="sidebar">
      <div class="sidebar-title">管理员功能</div>
      <%- include('../partials/sidebar-admin', { currentPage }) %>
    </div>

    <div class="main-content">
      <h4 class="mb-4"><i class="bi bi-bar-chart-line me-2"></i><%= title %></h4>

      <!-- 筛选栏 -->
      <div class="card shadow-sm mb-3">
        <div class="card-body">
          <div class="row g-3 align-items-end">
            <div class="col-md-2">
              <label class="form-label">开始日期</label>
              <input type="date" class="form-control" id="filterStartDate">
            </div>
            <div class="col-md-2">
              <label class="form-label">结束日期</label>
              <input type="date" class="form-control" id="filterEndDate">
            </div>
            <div class="col-md-3">
              <label class="form-label">销售门店</label>
              <select class="form-select" id="filterStore">
                <option value="">全部门店</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">商品（可多选，默认全部）</label>
              <select class="form-select" id="filterProducts" multiple style="height:120px">
              </select>
              <div class="form-text">按住Ctrl可多选，不选则查询全部商品</div>
            </div>
            <div class="col-md-2">
              <button class="btn btn-primary w-100" onclick="loadReport()">
                <i class="bi bi-search"></i> 统计
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- 统计结果 -->
      <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <h5 class="mb-0">销售统计 <span class="text-muted small" id="reportDate"></span></h5>
          <div>
            <span class="text-muted small me-3" id="totalInfo"></span>
            <button class="btn btn-outline-success btn-sm" onclick="exportCSV()" id="exportBtn" style="display:none">
              <i class="bi bi-download"></i> 导出CSV
            </button>
          </div>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>门店编码</th>
                  <th>商品条码</th>
                  <th>商品名称</th>
                  <th>销售总数量</th>
                  <th>记录笔数</th>
                  <th style="width:80px">操作</th>
                </tr>
              </thead>
              <tbody id="reportTableBody">
                <tr><td colspan="6" class="text-center text-muted py-4">请选择日期后点击"统计"按钮</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 销售明细弹窗 -->
  <div class="modal fade" id="detailModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">
            <i class="bi bi-list-ul me-2"></i>销售明细
            <span class="text-muted small" id="detailTitle"></span>
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>销售人员</th>
                  <th>销售日期</th>
                  <th>销售数量</th>
                  <th>登记时间</th>
                </tr>
              </thead>
              <tbody id="detailTableBody">
                <tr><td colspan="4" class="text-center text-muted py-3">加载中...</td></tr>
              </tbody>
            </table>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">关闭</button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // 日期格式化：直接从 ISO 字符串截取，不经过时区转换
    function fmtDate(isoStr) {
      if (!isoStr) return '-';
      return isoStr.replace('T', ' ').slice(0, 19);
    }

    const detailModal = new bootstrap.Modal(document.getElementById('detailModal'));
    let currentReportData = [];
    let currentQueryParams = '';

    (function initDates() {
      const today = new Date().toISOString().slice(0, 10);
      document.getElementById('filterStartDate').value = today;
      document.getElementById('filterEndDate').value = today;
    })();

    async function loadStoreFilter() {
      try {
        const res = await fetch('/api/admin/stores');
        const stores = await res.json();
        const sel = document.getElementById('filterStore');
        stores.forEach(s => { sel.innerHTML += `<option value="${s.store_code}">${s.store_code} - ${s.store_name}</option>`; });
      } catch (e) { document.getElementById('filterStore').innerHTML += '<option disabled>加载失败</option>'; }
    }
    loadStoreFilter();

    async function loadProductFilter() {
      try {
        const res = await fetch('/api/admin/products');
        const products = await res.json();
        const active = products.filter(p => p.status === 1);
        const sel = document.getElementById('filterProducts');
        sel.innerHTML = active.map(p => `<option value="${p.id}">${p.product_name} (${p.product_code})</option>`).join('');
      } catch (e) { document.getElementById('filterProducts').innerHTML = '<option disabled>加载失败</option>'; }
    }
    loadProductFilter();

    async function loadReport() {
      const startDate = document.getElementById('filterStartDate').value;
      const endDate = document.getElementById('filterEndDate').value;
      const storeCode = document.getElementById('filterStore').value;
      const productSelect = document.getElementById('filterProducts');
      const selectedProducts = Array.from(productSelect.selectedOptions).map(o => o.value);

      if (!startDate || !endDate) {
        document.getElementById('reportTableBody').innerHTML =
          '<tr><td colspan="6" class="text-center text-warning py-4">请选择查询日期范围</td></tr>';
        document.getElementById('exportBtn').style.display = 'none';
        return;
      }

      const params = new URLSearchParams();
      params.set('start_date', startDate);
      params.set('end_date', endDate);
      if (storeCode) params.set('store_code', storeCode);
      if (selectedProducts.length > 0) params.set('product_ids', selectedProducts.join(','));
      currentQueryParams = params.toString();

      document.getElementById('reportDate').textContent = `（${startDate} ~ ${endDate}）`;

      try {
        const res = await fetch('/api/admin/reports?' + params.toString());
        const result = await res.json();
        const tbody = document.getElementById('reportTableBody');
        currentReportData = result.data || [];

        if (!result.data || result.data.length === 0) {
          tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">该日期范围暂无销售数据</td></tr>';
          document.getElementById('totalInfo').textContent = '';
          document.getElementById('exportBtn').style.display = 'none';
          return;
        }

        let grandTotal = 0;
        tbody.innerHTML = result.data.map(r => {
          grandTotal += parseInt(r.total_quantity);
          return `<tr>
            <td><code>${r.store_code}</code></td>
            <td><code class="text-muted">${r.product_code || '-'}</code></td>
            <td>${r.product_name}</td>
            <td><span class="badge bg-primary fs-6">${r.total_quantity}</span></td>
            <td>${r.record_count} 笔</td>
            <td>
              <button class="btn btn-outline-info btn-sm" title="查看明细"
                onclick="showDetail('${r.store_code}', ${r.product_id}, '${r.product_name}')">
                <i class="bi bi-eye"></i> 详情
              </button>
            </td></tr>`;
        }).join('');

        document.getElementById('totalInfo').textContent =
          `共 ${result.data.length} 条汇总记录 | 合计销量: ${grandTotal}`;
        document.getElementById('exportBtn').style.display = '';
      } catch (err) {
        document.getElementById('reportTableBody').innerHTML =
          '<tr><td colspan="6" class="text-center text-danger py-4">查询失败</td></tr>';
        document.getElementById('exportBtn').style.display = 'none';
      }
    }

    async function showDetail(storeCode, productId, productName) {
      const startDate = document.getElementById('filterStartDate').value;
      const endDate = document.getElementById('filterEndDate').value;
      document.getElementById('detailTitle').textContent =
        `门店: ${storeCode} | 商品: ${productName} | ${startDate} ~ ${endDate}`;

      const detailBody = document.getElementById('detailTableBody');
      detailBody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-3">加载中...</td></tr>';
      detailModal.show();

      try {
        const params = new URLSearchParams({
          start_date: startDate,
          end_date: endDate,
          store_code: storeCode,
          product_id: productId,
        });
        const res = await fetch('/api/admin/reports/detail?' + params.toString());
        const result = await res.json();

        if (!result.data || result.data.length === 0) {
          detailBody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-3">暂无明细数据</td></tr>';
          return;
        }

        detailBody.innerHTML = result.data.map(r => `
          <tr>
            <td>${r.sales_person_name}</td>
            <td>${fmtDate(r.sale_date)}</td>
            <td><span class="badge bg-info">${r.quantity}</span></td>
            <td>${fmtDate(r.recorded_at)}</td>
          </tr>
        `).join('');
      } catch (err) {
        detailBody.innerHTML = '<tr><td colspan="4" class="text-center text-danger py-3">加载失败</td></tr>';
      }
    }

    function exportCSV() {
      if (!currentQueryParams) return;
      window.open('/api/admin/reports/export?' + currentQueryParams, '_blank');
    }

    setTimeout(loadReport, 500);
  </script>
</body>
</html>

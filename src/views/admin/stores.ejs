<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>门店管理 - 门店销售统计系统</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/header', { user }) %>

  <div class="layout-container">
    <div class="sidebar">
      <div class="sidebar-title">管理员功能</div>
      <%- include('../partials/sidebar-admin', { currentPage }) %>
    </div>

    <div class="main-content">
      <h4 class="mb-4"><i class="bi bi-building me-2"></i><%= title %></h4>

      <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <h5 class="mb-0">门店列表</h5>
          <button class="btn btn-success btn-sm" onclick="openAddModal()">
            <i class="bi bi-plus-lg"></i> 新增门店
          </button>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>门店编码</th>
                  <th>门店名称</th>
                  <th>联系人</th>
                  <th>联系电话</th>
                  <th>联系人2</th>
                  <th>联系电话2</th>
                  <th>门店地址</th>
                  <th style="width:80px">操作</th>
                </tr>
              </thead>
              <tbody id="storeTableBody"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 新增/编辑门店模态框 -->
  <div class="modal fade" id="storeModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="storeModalTitle">新增门店</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div id="modalMsg"></div>
          <input type="hidden" id="editStoreId">
          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label">门店编码 <span class="text-danger">*</span></label>
              <input type="text" class="form-control" id="editStoreCode" placeholder="唯一值，必填">
            </div>
            <div class="col-md-4">
              <label class="form-label">门店名称 <span class="text-danger">*</span></label>
              <input type="text" class="form-control" id="editStoreName" placeholder="必填">
            </div>
            <div class="col-md-4">
              <label class="form-label">门店地址</label>
              <input type="text" class="form-control" id="editAddress" placeholder="非必填">
            </div>
            <div class="col-md-3">
              <label class="form-label">联系人</label>
              <input type="text" class="form-control" id="editContactPerson" placeholder="非必填">
            </div>
            <div class="col-md-3">
              <label class="form-label">联系电话</label>
              <input type="text" class="form-control" id="editContactPhone" placeholder="非必填">
            </div>
            <div class="col-md-3">
              <label class="form-label">联系人2</label>
              <input type="text" class="form-control" id="editContactPerson2" placeholder="非必填">
            </div>
            <div class="col-md-3">
              <label class="form-label">联系电话2</label>
              <input type="text" class="form-control" id="editContactPhone2" placeholder="非必填">
            </div>
            <div class="col-12">
              <label class="form-label">在售商品（选填，可多选）</label>
              <div class="border rounded p-2" style="max-height:150px;overflow-y:auto" id="editStoreProducts">
                <span class="text-muted small">加载中...</span>
              </div>
              <div class="form-text">仅显示启用状态的商品</div>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
          <button type="button" class="btn btn-primary" id="saveStoreBtn" onclick="saveStore()">保存</button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const storeModal = new bootstrap.Modal(document.getElementById('storeModal'));

    async function loadStoreProducts() {
      try {
        const res = await fetch('/api/admin/products');
        const products = await res.json();
        const active = products.filter(p => p.status === 1);
        const container = document.getElementById('editStoreProducts');
        container.innerHTML = active.length === 0 ? '<span class="text-muted small">暂无启用商品</span>' :
          active.map(p => `
            <div class="form-check">
              <input class="form-check-input store-product-check" type="checkbox" value="${p.id}" id="sp_${p.id}">
              <label class="form-check-label small" for="sp_${p.id}">${p.product_name} (${p.product_code})</label>
            </div>`).join('');
      } catch (e) { /* ignore */ }
    }
    loadStoreProducts();

    async function loadStores() {
      try {
        const res = await fetch('/api/admin/stores');
        const stores = await res.json();
        const tbody = document.getElementById('storeTableBody');
        if (!stores.length) {
          tbody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-4">暂无门店数据</td></tr>';
          return;
        }
        tbody.innerHTML = stores.map(s => `
          <tr>
            <td><code>${s.store_code}</code></td>
            <td>${s.store_name}</td>
            <td>${s.contact_person || '-'}</td>
            <td>${s.contact_phone || '-'}</td>
            <td>${s.contact_person2 || '-'}</td>
            <td>${s.contact_phone2 || '-'}</td>
            <td class="text-truncate" style="max-width:150px">${s.address || '-'}</td>
            <td>
              <button class="btn btn-outline-primary btn-sm" onclick="openEditModal(${s.id})" title="修改">
                <i class="bi bi-pencil"></i>
              </button>
              <button class="btn btn-outline-danger btn-sm" onclick="deleteStore(${s.id}, '${s.store_name}')" title="删除">
                <i class="bi bi-trash"></i>
              </button>
            </td>
          </tr>`).join('');
      } catch (err) {
        document.getElementById('storeTableBody').innerHTML =
          '<tr><td colspan="8" class="text-center text-danger py-4">加载失败</td></tr>';
      }
    }

    function openAddModal() {
      document.getElementById('storeModalTitle').textContent = '新增门店';
      document.getElementById('editStoreId').value = '';
      document.getElementById('editStoreCode').value = '';
      document.getElementById('editStoreCode').disabled = false;
      document.getElementById('editStoreName').value = '';
      document.getElementById('editContactPerson').value = '';
      document.getElementById('editContactPhone').value = '';
      document.getElementById('editContactPerson2').value = '';
      document.getElementById('editContactPhone2').value = '';
      document.getElementById('editAddress').value = '';
      document.querySelectorAll('.store-product-check').forEach(cb => cb.checked = false);
      document.getElementById('modalMsg').innerHTML = '';
      document.getElementById('saveStoreBtn').textContent = '保存';
      storeModal.show();
    }

    async function openEditModal(id) {
      try {
        const res = await fetch('/api/admin/stores/' + id);
        const s = await res.json();
        document.getElementById('storeModalTitle').textContent = '修改门店';
        document.getElementById('editStoreId').value = s.id;
        document.getElementById('editStoreCode').value = s.store_code;
        document.getElementById('editStoreCode').disabled = true;
        document.getElementById('editStoreName').value = s.store_name;
        document.getElementById('editContactPerson').value = s.contact_person || '';
        document.getElementById('editContactPhone').value = s.contact_phone || '';
        document.getElementById('editContactPerson2').value = s.contact_person2 || '';
        document.getElementById('editContactPhone2').value = s.contact_phone2 || '';
        document.getElementById('editAddress').value = s.address || '';
        document.querySelectorAll('.store-product-check').forEach(cb => {
          cb.checked = (s.product_ids || []).includes(parseInt(cb.value));
        });
        document.getElementById('modalMsg').innerHTML = '';
        document.getElementById('saveStoreBtn').textContent = '保存修改';
        storeModal.show();
      } catch (err) {
        alert('加载门店信息失败');
      }
    }

    async function saveStore() {
      const id = document.getElementById('editStoreId').value;
      const storeCode = document.getElementById('editStoreCode').value.trim();
      const storeName = document.getElementById('editStoreName').value.trim();
      const productIds = Array.from(document.querySelectorAll('.store-product-check:checked')).map(cb => parseInt(cb.value));
      const msgEl = document.getElementById('modalMsg');

      if (!storeCode) { msgEl.innerHTML = '<div class="alert alert-warning">门店编码必填</div>'; return; }
      if (!storeName) { msgEl.innerHTML = '<div class="alert alert-warning">门店名称必填</div>'; return; }

      const body = {
        store_code: storeCode,
        store_name: storeName,
        contact_person: document.getElementById('editContactPerson').value.trim(),
        contact_phone: document.getElementById('editContactPhone').value.trim(),
        contact_person2: document.getElementById('editContactPerson2').value.trim(),
        contact_phone2: document.getElementById('editContactPhone2').value.trim(),
        address: document.getElementById('editAddress').value.trim(),
        product_ids: productIds,
      };

      try {
        const url = id ? '/api/admin/stores/' + id : '/api/admin/stores';
        const method = id ? 'PUT' : 'POST';
        const res = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const data = await res.json();
        if (data.success) {
          storeModal.hide();
          loadStores();
        } else {
          msgEl.innerHTML = `<div class="alert alert-danger">${data.error}</div>`;
        }
      } catch (err) {
        msgEl.innerHTML = '<div class="alert alert-danger">操作失败</div>';
      }
    }

    // 删除门店
    async function deleteStore(id, name) {
      if (!confirm(`确定要删除门店「${name}」吗？\n\n此操作将同时清除该门店的在售商品关联和销售记录，该门店下的用户门店归属将被置空。不可恢复。`)) return;
      try {
        const res = await fetch('/api/admin/stores/' + id, { method: 'DELETE' });
        const data = await res.json();
        if (data.success) {
          loadStores();
        } else {
          alert(data.error || '删除失败');
        }
      } catch (err) {
        alert('删除失败，请重试');
      }
    }

    loadStores();
  </script>
</body>
</html>

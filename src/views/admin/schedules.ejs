<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>排班管理 - 门店销售统计系统</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/header', { user }) %>

  <div class="layout-container">
    <div class="sidebar">
      <div class="sidebar-title">管理员功能</div>
      <%- include('../partials/sidebar-admin', { currentPage }) %>
    </div>

    <div class="main-content">
      <h4 class="mb-3"><i class="bi bi-calendar-check me-2"></i><%= title %></h4>

      <div class="row g-2 align-items-center mb-3">
        <div class="col-md-3">
          <select class="form-select" id="storeSelect">
            <option value="">-- 请选择门店 --</option>
          </select>
        </div>
        <div class="col-md-auto">
          <span class="text-secondary" style="font-size:0.85rem;">选择门店后自动加载当月排班</span>
        </div>
      </div>

      <div id="calendarArea">
        <div class="calendar-wrap" style="min-height:300px;">
          <div class="text-center py-5" id="calendarPlaceholder" style="color:var(--s400);">
            <i class="bi bi-building" style="font-size:2.5rem;opacity:.25;"></i>
            <p class="mt-2">请先选择门店查看排班</p>
          </div>
          <div id="calendarContent" style="display:none;"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- 编辑排班弹窗 -->
  <div class="modal fade" id="scheduleModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="modalTitle">排班编辑</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div id="modalMsg"></div>
          <div id="staffCheckList"></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary btn-sm" onclick="selectAllStaff(true)">全选</button>
          <button type="button" class="btn btn-outline-secondary btn-sm" onclick="selectAllStaff(false)">全不选</button>
          <button type="button" class="btn btn-primary" onclick="saveDaySchedule()">
            <i class="bi bi-check-lg"></i> 保存
          </button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let currentYear, currentMonth;
    let currentStoreCode = '';
    let allStaff = [];
    let scheduleMap = {};
    let editingDate = '';
    const scheduleModal = new bootstrap.Modal(document.getElementById('scheduleModal'));

    document.addEventListener('DOMContentLoaded', () => {
      const now = new Date();
      currentYear = now.getFullYear();
      currentMonth = now.getMonth() + 1;
      loadStores();
    });

    async function loadStores() {
      try {
        const res = await fetch('/api/admin/stores');
        const stores = await res.json();
        const sel = document.getElementById('storeSelect');
        stores.forEach(s => {
          sel.innerHTML += `<option value="${s.store_code}">${s.store_name} (${s.store_code})</option>`;
        });
        sel.addEventListener('change', onStoreChange);
      } catch (err) {
        console.error('加载门店失败:', err);
      }
    }

    function onStoreChange() {
      currentStoreCode = document.getElementById('storeSelect').value;
      if (!currentStoreCode) {
        document.getElementById('calendarPlaceholder').style.display = '';
        document.getElementById('calendarContent').style.display = 'none';
        return;
      }
      document.getElementById('calendarPlaceholder').style.display = 'none';
      renderCalendar();
    }

    function changeMonth(delta) {
      if (!currentStoreCode) return;
      currentMonth += delta;
      if (currentMonth < 1) { currentMonth = 12; currentYear--; }
      if (currentMonth > 12) { currentMonth = 1; currentYear++; }
      renderCalendar();
    }

    function goToday() {
      if (!currentStoreCode) return;
      const now = new Date();
      currentYear = now.getFullYear();
      currentMonth = now.getMonth() + 1;
      renderCalendar();
    }

    async function renderCalendar() {
      document.getElementById('calendarContent').style.display = '';
      document.getElementById('calendarContent').innerHTML =
        '<div class="text-center py-5"><div class="spinner-border text-primary"></div></div>';

      const firstDay = new Date(currentYear, currentMonth - 1, 1);
      const lastDay = new Date(currentYear, currentMonth, 0);
      const startDate = firstDay.toISOString().slice(0, 10);
      const endDate = lastDay.toISOString().slice(0, 10);

      try {
        const [staffRes, schedRes] = await Promise.all([
          fetch(`/api/admin/schedules/users?store_code=${currentStoreCode}`),
          fetch(`/api/admin/schedules?start_date=${startDate}&end_date=${endDate}&store_code=${currentStoreCode}`),
        ]);
        allStaff = await staffRes.json();
        const schedData = await schedRes.json();

        scheduleMap = {};
        schedData.data.forEach(s => {
          if (!scheduleMap[s.schedule_date]) scheduleMap[s.schedule_date] = [];
          scheduleMap[s.schedule_date].push({ id: s.user_id, name: s.user_name || '' });
        });

        buildCalendarHTML(firstDay, lastDay);
      } catch (err) {
        document.getElementById('calendarContent').innerHTML =
          '<div class="alert alert-danger m-3">加载排班数据失败</div>';
      }
    }

    function buildCalendarHTML(firstDay, lastDay) {
      const today = new Date().toISOString().slice(0, 10);
      const startDayOfWeek = firstDay.getDay();
      const dayHeaders = ['日', '一', '二', '三', '四', '五', '六'];

      let html = '<div class="calendar-toolbar">';
      html += `<button class="btn-month" onclick="changeMonth(-1)"><i class="bi bi-chevron-left"></i></button>`;
      html += `<span class="month-title">${currentYear}年 ${currentMonth}月</span>`;
      html += `<button class="btn-month" onclick="changeMonth(1)"><i class="bi bi-chevron-right"></i></button>`;
      html += `<button class="btn-today ms-3" onclick="goToday()"><i class="bi bi-calendar-week me-1"></i>本月</button>`;
      html += '</div>';

      html += '<div class="calendar-grid">';
      dayHeaders.forEach((d, i) => {
        const cls = (i === 0 || i === 6) ? 'calendar-day-header weekend' : 'calendar-day-header';
        html += `<div class="${cls}">${d}</div>`;
      });
      html += '</div>';

      html += '<div class="calendar-grid">';
      for (let i = 0; i < startDayOfWeek; i++) {
        html += '<div class="calendar-cell other-month"></div>';
      }

      const staffStatus = {};
      allStaff.forEach(s => { staffStatus[s.id] = s.status; });

      for (let d = 1; d <= lastDay.getDate(); d++) {
        const dateStr = `${currentYear}-${String(currentMonth).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
        const dayOfWeek = new Date(currentYear, currentMonth - 1, d).getDay();
        const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;
        const isToday = dateStr === today;
        const staffList = scheduleMap[dateStr] || [];

        let cls = 'calendar-cell clickable';
        if (isToday) cls += ' today';

        let dayHtml = isToday
          ? `<span class="day-num today-num">${d}</span>`
          : `<span class="day-num${isWeekend ? ' weekend' : ''}">${d}</span>`;

        let tagsHtml = '';
        const maxShow = 3;
        staffList.slice(0, maxShow).forEach(item => {
          const isDisabled = staffStatus[item.id] === 'disabled';
          const tagCls = isDisabled ? 'staff-tag disabled-tag' : 'staff-tag';
          tagsHtml += `<span class="${tagCls}">${item.name || '?'}</span>`;
        });
        if (staffList.length > maxShow) {
          tagsHtml += `<span class="staff-tag more-tag">+${staffList.length - maxShow}</span>`;
        }

        html += `<div class="${cls}" onclick="openDayEditor('${dateStr}')">${dayHtml}${tagsHtml}</div>`;
      }

      const totalCells = startDayOfWeek + lastDay.getDate();
      const remaining = (7 - (totalCells % 7)) % 7;
      for (let i = 0; i < remaining; i++) {
        html += '<div class="calendar-cell other-month"></div>';
      }

      html += '</div>';
      document.getElementById('calendarContent').innerHTML = html;
    }

    function openDayEditor(dateStr) {
      editingDate = dateStr;
      const staffList = scheduleMap[dateStr] || [];
      const checkedIds = new Set(staffList.map(item => item.id));

      document.getElementById('modalTitle').textContent = `排班编辑 — ${dateStr}`;
      document.getElementById('modalMsg').innerHTML = '';

      if (allStaff.length === 0) {
        document.getElementById('staffCheckList').innerHTML = '<div class="text-muted">该门店下暂无店员</div>';
      } else {
        let html = '';
        allStaff.forEach(s => {
          const isDisabled = s.status !== 'active';
          html += `<div class="staff-check-item">
            <div class="form-check">
              <input class="form-check-input staff-cb" type="checkbox" value="${s.id}"
                id="staff_${s.id}" ${checkedIds.has(s.id) ? 'checked' : ''}>
              <label class="form-check-label" for="staff_${s.id}">
                ${s.name}
                ${isDisabled ? '<span class="badge bg-secondary ms-1" style="font-size:.65rem;">已离职</span>' : ''}
              </label>
            </div>
          </div>`;
        });
        document.getElementById('staffCheckList').innerHTML = html;
      }
      scheduleModal.show();
    }

    function selectAllStaff(check) {
      document.querySelectorAll('.staff-cb').forEach(cb => { cb.checked = check; });
    }

    async function saveDaySchedule() {
      const checkedIds = [];
      document.querySelectorAll('.staff-cb:checked').forEach(cb => { checkedIds.push(parseInt(cb.value)); });

      try {
        const res = await fetch('/api/admin/schedules', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ date: editingDate, store_code: currentStoreCode, user_ids: checkedIds }),
        });
        const data = await res.json();
        if (data.success) {
          const nameMap = {};
          allStaff.forEach(s => { nameMap[s.id] = s.name; });
          scheduleMap[editingDate] = checkedIds.map(id => ({ id, name: nameMap[id] || '' }));
          buildCalendarHTML(new Date(currentYear, currentMonth - 1, 1), new Date(currentYear, currentMonth, 0));
          document.getElementById('modalMsg').innerHTML =
            '<div class="alert alert-success py-1 mb-0"><i class="bi bi-check-circle"></i> 保存成功</div>';
          setTimeout(() => { scheduleModal.hide(); }, 600);
        } else {
          document.getElementById('modalMsg').innerHTML = `<div class="alert alert-danger py-1 mb-0">${data.error}</div>`;
        }
      } catch (err) {
        document.getElementById('modalMsg').innerHTML = '<div class="alert alert-danger py-1 mb-0">保存失败</div>';
      }
    }
  </script>
</body>
</html>

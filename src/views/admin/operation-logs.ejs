<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>操作日志 - 门店销售统计系统</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/header', { user }) %>

  <div class="layout-container">
    <div class="sidebar">
      <div class="sidebar-title text-muted small px-3 py-2">管理员功能</div>
      <%- include('../partials/sidebar-admin', { currentPage }) %>
    </div>

    <div class="main-content">
      <h4 class="mb-4"><i class="bi bi-journal-text me-2"></i><%= title %></h4>

      <div class="card shadow-sm mb-3">
        <div class="card-body">
          <div class="row g-3 align-items-end">
            <div class="col-md-2">
              <label class="form-label">开始日期</label>
              <input type="date" class="form-control" id="filterStartDate">
            </div>
            <div class="col-md-2">
              <label class="form-label">结束日期</label>
              <input type="date" class="form-control" id="filterEndDate">
            </div>
            <div class="col-md-2">
              <label class="form-label">操作人手机号</label>
              <input type="text" class="form-control" id="filterPhone" placeholder="模糊搜索">
            </div>
            <div class="col-md-2">
              <label class="form-label">操作人姓名</label>
              <input type="text" class="form-control" id="filterName" placeholder="模糊搜索">
            </div>
            <div class="col-md-2">
              <button class="btn btn-primary w-100" onclick="loadLogs(1)">
                <i class="bi bi-search"></i> 查询
              </button>
            </div>
            <div class="col-md-2">
              <button class="btn btn-outline-warning w-100" onclick="clearOldLogs()" title="清空45天前的日志">
                <i class="bi bi-eraser"></i> 清理旧日志
              </button>
            </div>
          </div>
        </div>
      </div>

      <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <h5 class="mb-0">操作记录</h5>
          <span class="text-muted small" id="totalInfo"></span>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>操作时间</th>
                  <th>操作人</th>
                  <th>手机号</th>
                  <th>IP地址</th>
                  <th>操作内容</th>
                </tr>
              </thead>
              <tbody id="tableBody">
                <tr><td colspan="5" class="text-center text-muted py-4">点击查询按钮加载数据</td></tr>
              </tbody>
            </table>
          </div>
        </div>
        <div class="card-footer bg-white">
          <nav id="pagination"></nav>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const pageSize = 20;
    let currentPage = 1;

    function fmtDate(isoStr) {
      if (!isoStr) return '-';
      return isoStr.replace('T', ' ').slice(0, 19);
    }

    async function loadLogs(page) {
      currentPage = page || 1;
      const params = new URLSearchParams();
      const phone = document.getElementById('filterPhone').value.trim();
      const name = document.getElementById('filterName').value.trim();
      const startDate = document.getElementById('filterStartDate').value;
      const endDate = document.getElementById('filterEndDate').value;
      if (phone) params.set('user_phone', phone);
      if (name) params.set('user_name', name);
      if (startDate) params.set('start_date', startDate);
      if (endDate) params.set('end_date', endDate);
      params.set('page', currentPage);
      params.set('page_size', pageSize);

      try {
        const res = await fetch('/api/admin/operation-logs?' + params.toString());
        const result = await res.json();
        document.getElementById('totalInfo').textContent = `共 ${result.total} 条`;

        const tbody = document.getElementById('tableBody');
        if (!result.data || result.data.length === 0) {
          tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-4">暂无操作日志</td></tr>';
          renderPagination(0, 1);
          return;
        }

        tbody.innerHTML = result.data.map(r => `
          <tr>
            <td>${fmtDate(r.created_at)}</td>
            <td>${r.user_name}</td>
            <td>${r.user_phone}</td>
            <td><code>${r.ip_address || '-'}</code></td>
            <td>${r.action}</td>
          </tr>
        `).join('');

        renderPagination(result.total_pages, currentPage);
      } catch (err) {
        document.getElementById('tableBody').innerHTML =
          '<tr><td colspan="5" class="text-center text-danger py-4">加载失败</td></tr>';
      }
    }

    function renderPagination(totalPages, current) {
      const nav = document.getElementById('pagination');
      if (totalPages <= 1) { nav.innerHTML = ''; return; }
      let html = '<ul class="pagination pagination-sm justify-content-center mb-0">';
      html += `<li class="page-item ${current === 1 ? 'disabled' : ''}">
        <a class="page-link" href="#" onclick="loadLogs(${current - 1});return false">上一页</a></li>`;
      for (let i = 1; i <= totalPages; i++) {
        html += `<li class="page-item ${i === current ? 'active' : ''}">
          <a class="page-link" href="#" onclick="loadLogs(${i});return false">${i}</a></li>`;
      }
      html += `<li class="page-item ${current === totalPages ? 'disabled' : ''}">
        <a class="page-link" href="#" onclick="loadLogs(${current + 1});return false">下一页</a></li>`;
      html += '</ul>';
      nav.innerHTML = html;
    }

    async function clearOldLogs() {
      if (!confirm('确定要清空45天以前的所有操作日志吗？此操作不可恢复。')) return;
      try {
        const res = await fetch('/api/admin/operation-logs', { method: 'DELETE' });
        const data = await res.json();
        alert(data.message || '操作完成');
        loadLogs(1);
      } catch (err) {
        alert('操作失败');
      }
    }

    loadLogs(1);
  </script>
</body>
</html>

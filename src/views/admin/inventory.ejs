<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>库存报表 - 门店销售统计系统</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <style>
    .sortable { cursor: pointer; user-select: none; }
    .sortable:hover { color: var(--primary); }
    .sort-icon { font-size: .7rem; opacity: .4; margin-left: 2px; }
    .sort-icon.active { opacity: 1; color: var(--primary); }
  </style>
</head>
<body>
  <%- include('../partials/header', { user }) %>
  <div class="layout-container">
    <div class="sidebar">
      <div class="sidebar-title">管理员功能</div>
      <%- include('../partials/sidebar-admin', { currentPage }) %>
    </div>
    <div class="main-content">
      <h4 class="mb-3"><i class="bi bi-boxes me-2"></i><%= title %></h4>

      <div class="card shadow-sm mb-3">
        <div class="card-body">
          <div class="row g-3 align-items-end">
            <div class="col-md-3">
              <label class="form-label">门店</label>
              <select class="form-select" id="filterStore"><option value="">全部门店</option></select>
            </div>
            <div class="col-md-3">
              <label class="form-label">商品</label>
              <select class="form-select" id="filterProduct"><option value="">全部商品</option></select>
            </div>
            <div class="col-md-2">
              <label class="form-label">开始日期</label>
              <input type="date" class="form-control" id="filterStartDate">
            </div>
            <div class="col-md-2">
              <label class="form-label">结束日期</label>
              <input type="date" class="form-control" id="filterEndDate">
            </div>
            <div class="col-md-2">
              <button class="btn btn-primary w-100" onclick="loadData()"><i class="bi bi-search"></i> 查询</button>
            </div>
          </div>
        </div>
      </div>

      <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between">
          <h5 class="mb-0">库存记录</h5>
          <div>
            <button class="btn btn-outline-success btn-sm me-2" onclick="exportCSV()"><i class="bi bi-download"></i> 导出CSV</button>
            <span class="text-muted small" id="totalInfo"></span>
          </div>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th class="sortable" onclick="sortBy('store_code')">门店 <span class="sort-icon" id="si-store_code">↕</span></th>
                  <th>商品条码</th>
                  <th>商品名称</th>
                  <th class="sortable" onclick="sortBy('quantity')">库存数量 <span class="sort-icon" id="si-quantity">↕</span></th>
                  <th class="sortable" onclick="sortBy('record_date')">记录日期 <span class="sort-icon" id="si-record_date">↕</span></th>
                  <th class="sortable" onclick="sortBy('updated_at')">更新时间 <span class="sort-icon active" id="si-updated_at">↓</span></th>
                </tr>
              </thead>
              <tbody id="tableBody">
                <tr><td colspan="6" class="text-center text-muted py-4">请选择条件后点击查询</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function fmtDate(v) {
      if (!v) return '-';
      var d = new Date(v);
      return d.getFullYear() + '-' + ('0'+(d.getMonth()+1)).slice(-2) + '-' + ('0'+d.getDate()).slice(-2)
        + ' ' + ('0'+d.getHours()).slice(-2) + ':' + ('0'+d.getMinutes()).slice(-2) + ':' + ('0'+d.getSeconds()).slice(-2);
    }

    var allData = [];
    var sortField = 'updated_at';
    var sortDir = 'desc';

    (function init() {
      var today = new Date().toISOString().slice(0, 10);
      document.getElementById('filterStartDate').value = today;
      document.getElementById('filterEndDate').value = today;
      loadFilters();
      loadData();
    })();

    async function loadFilters() {
      try {
        var [storesRes, productsRes] = await Promise.all([
          fetch('/api/admin/stores'), fetch('/api/admin/products')
        ]);
        var stores = await storesRes.json();
        var products = await productsRes.json();
        var ss = document.getElementById('filterStore');
        stores.forEach(s => { ss.innerHTML += '<option value="' + s.store_code + '">' + s.store_name + '</option>'; });
        var ps = document.getElementById('filterProduct');
        products.forEach(p => { ps.innerHTML += '<option value="' + p.id + '">' + p.product_name + ' (' + p.product_code + ')</option>'; });
      } catch (e) {}
    }

    async function loadData() {
      var params = new URLSearchParams();
      var store = document.getElementById('filterStore').value;
      var product = document.getElementById('filterProduct').value;
      var sd = document.getElementById('filterStartDate').value;
      var ed = document.getElementById('filterEndDate').value;
      if (store) params.set('store_code', store);
      if (product) params.set('product_id', product);
      if (sd) params.set('start_date', sd);
      if (ed) params.set('end_date', ed);

      try {
        var res = await fetch('/api/admin/inventory?' + params.toString());
        var result = await res.json();
        allData = result.data;
        sortData();
      } catch (e) {
        document.getElementById('tableBody').innerHTML = '<tr><td colspan="6" class="text-center text-danger py-4">加载失败</td></tr>';
      }
    }

    function sortBy(field) {
      if (sortField === field) { sortDir = sortDir === 'asc' ? 'desc' : 'asc'; }
      else { sortField = field; sortDir = 'desc'; }
      sortData();
    }

    function sortData() {
      var data = allData.slice();
      data.sort(function(a, b) {
        var va = a[sortField] !== undefined ? a[sortField] : '';
        var vb = b[sortField] !== undefined ? b[sortField] : '';
        if (typeof va === 'number') return sortDir === 'asc' ? va - vb : vb - va;
        return sortDir === 'asc' ? String(va).localeCompare(String(vb)) : String(vb).localeCompare(String(va));
      });

      // 更新排序图标
      document.querySelectorAll('.sort-icon').forEach(function(el) { el.className = 'sort-icon'; });
      var si = document.getElementById('si-' + sortField);
      if (si) { si.className = 'sort-icon active'; si.textContent = sortDir === 'asc' ? '↑' : '↓'; }

      var tbody = document.getElementById('tableBody');
      document.getElementById('totalInfo').textContent = '共 ' + data.length + ' 条';
      if (!data.length) {
        tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">暂无数据</td></tr>';
        return;
      }
      tbody.innerHTML = data.map(function(r) {
        return '<tr><td>' + r.store_name + ' <code>' + r.store_code + '</code></td>' +
          '<td><code>' + r.product_code + '</code></td>' +
          '<td>' + r.product_name + '</td>' +
          '<td><span class="badge bg-primary">' + r.quantity + '</span></td>' +
          '<td>' + r.record_date + '</td>' +
          '<td>' + fmtDate(r.updated_at) + '</td></tr>';
      }).join('');
    }

    function exportCSV() {
      var params = new URLSearchParams();
      var store = document.getElementById('filterStore').value;
      var product = document.getElementById('filterProduct').value;
      var sd = document.getElementById('filterStartDate').value;
      var ed = document.getElementById('filterEndDate').value;
      if (store) params.set('store_code', store);
      if (product) params.set('product_id', product);
      if (sd) params.set('start_date', sd);
      if (ed) params.set('end_date', ed);
      window.open('/api/admin/inventory/export?' + params.toString(), '_blank');
    }
  </script>
</body>
</html>

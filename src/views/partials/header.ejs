<!-- 公共头部 — 显示系统标题和当前用户信息 -->
<nav class="navbar">
  <div class="container-fluid">
    <!-- 移动端菜单按钮 -->
    <button class="btn d-md-none me-2" id="menuToggle" type="button" aria-label="菜单" style="border:none;background:transparent;color:var(--gray-500);">
      <i class="bi bi-list fs-4"></i>
    </button>
    <a class="navbar-brand" href="/home">
      <i class="bi bi-shop-window"></i> 门店销售统计系统
    </a>
    <div class="d-flex align-items-center ms-auto gap-3">
      <span class="d-none d-md-inline-flex align-items-center gap-2 text-secondary" style="font-size:0.85rem;">
        <i class="bi bi-person-circle" style="color:var(--primary-light);"></i>
        <span style="color:var(--gray-600);"><%= user.name %></span>
        <span class="badge" style="background:var(--primary-bg);color:var(--primary);font-weight:600;">
          <%= user.role === 'admin' ? '管理员' : '店员' %>
        </span>
      </span>
      <a href="/logout" class="btn btn-outline-secondary btn-sm d-flex align-items-center gap-1" style="border-color:var(--gray-200);">
        <i class="bi bi-box-arrow-right"></i> <span class="d-none d-sm-inline">退出</span>
      </a>
    </div>
  </div>
</nav>

<script>
// 移动端侧边栏折叠/展开
document.addEventListener('DOMContentLoaded', function() {
  var toggle = document.getElementById('menuToggle');
  var sidebar = document.querySelector('.sidebar');
  if (!toggle || !sidebar) return;

  // 创建遮罩层
  var overlay = document.createElement('div');
  overlay.className = 'sidebar-overlay';
  overlay.style.cssText = 'display:none;position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(0,0,0,0.4);z-index:1040;';
  document.body.appendChild(overlay);

  function openMenu() {
    sidebar.classList.add('sidebar-show');
    overlay.style.display = 'block';
  }
  function closeMenu() {
    sidebar.classList.remove('sidebar-show');
    overlay.style.display = 'none';
  }

  toggle.addEventListener('click', function(e) {
    e.stopPropagation();
    sidebar.classList.contains('sidebar-show') ? closeMenu() : openMenu();
  });

  overlay.addEventListener('click', closeMenu);

  // 点击菜单项后自动关闭
  sidebar.querySelectorAll('.list-group-item').forEach(function(item) {
    item.addEventListener('click', function() {
      setTimeout(closeMenu, 150);
    });
  });

  // ===== 收藏切换：注入到页面标题旁 =====
  var pageKey = '<%= typeof currentPage !== "undefined" ? currentPage : "" %>';
  if (pageKey && pageKey !== 'home') {
    var h4 = document.querySelector('.main-content h4');
    if (h4) {
      var btn = document.createElement('span');
      btn.className = 'fav-page-toggle';
      btn.title = '收藏此页面';
      btn.innerHTML = '<i class="bi bi-bookmark-plus"></i>';
      btn.style.cssText = 'cursor:pointer;font-size:1.1rem;margin-left:8px;opacity:.35;transition:all .2s;';
      btn.onmouseenter = function() { this.style.opacity = '.8'; };
      btn.onmouseleave = function() { if (!this.dataset.on) this.style.opacity = '.35'; };

      // 加载初始状态
      fetch('/api/favorites').then(function(r){return r.json()}).then(function(keys){
        if (keys.includes(pageKey)) {
          btn.innerHTML = '<i class="bi bi-bookmark-check-fill"></i>';
          btn.style.opacity = '.85';
          btn.dataset.on = '1';
        }
      }).catch(function(){});

      btn.onclick = function() {
        fetch('/api/favorites', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({page_key:pageKey})})
          .then(function(r){return r.json()}).then(function(d){
            if (d.favorited) {
              btn.innerHTML = '<i class="bi bi-bookmark-check-fill"></i>';
              btn.style.opacity = '.85';
              btn.dataset.on = '1';
            } else {
              btn.innerHTML = '<i class="bi bi-bookmark-plus"></i>';
              btn.style.opacity = '.35';
              btn.dataset.on = '';
            }
          });
      };
      h4.appendChild(btn);
    }
  }
});
</script>

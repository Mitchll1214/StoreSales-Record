<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>首页 - 门店销售统计系统</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <style>
    .welcome-hero {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      border-radius: 16px;
      padding: 40px 32px;
      color: #fff;
      margin-bottom: 24px;
    }
    .welcome-hero h2 {
      font-weight: 700;
      margin-bottom: 6px;
    }
    .welcome-hero .date-text {
      opacity: 0.8;
      font-size: 14px;
    }
    .quote-card {
      background: #fff;
      border-radius: 16px;
      padding: 32px 28px;
      margin-bottom: 24px;
      border-left: 5px solid #667eea;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      position: relative;
    }
    .quote-card .quote-icon {
      position: absolute;
      top: 16px;
      right: 20px;
      font-size: 48px;
      color: #e8ecf4;
    }
    .quote-card .quote-text {
      font-size: 20px;
      font-weight: 500;
      color: #2c3e50;
      line-height: 1.7;
      margin-bottom: 12px;
    }
    .quote-card .quote-from {
      text-align: right;
      color: #95a5a6;
      font-size: 14px;
    }
    .quote-card .quote-source {
      font-size: 11px;
      color: #bdc3c7;
      margin-top: 8px;
    }
    .quick-card {
      border-radius: 14px;
      padding: 24px 20px;
      text-align: center;
      transition: all 0.2s ease;
      cursor: pointer;
      color: #fff;
      text-decoration: none;
      display: block;
      height: 100%;
    }
    .quick-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 25px rgba(0,0,0,0.15);
      color: #fff;
    }
    .quick-card .card-icon {
      font-size: 36px;
      margin-bottom: 12px;
    }
    .quick-card .card-label {
      font-size: 15px;
      font-weight: 600;
    }
    .bg-card-1 { background: linear-gradient(135deg, #43e97b, #38f9d7); }
    .bg-card-2 { background: linear-gradient(135deg, #f093fb, #f5576c); }
    .bg-card-3 { background: linear-gradient(135deg, #4facfe, #00f2fe); }
    .bg-card-4 { background: linear-gradient(135deg, #fa709a, #fee140); }
    .bg-card-5 { background: linear-gradient(135deg, #a18cd1, #fbc2eb); }
    .bg-card-6 { background: linear-gradient(135deg, #667eea, #764ba2); }

    @media (max-width: 768px) {
      .welcome-hero {
        padding: 24px 20px;
      }
      .welcome-hero h2 {
        font-size: 20px;
      }
      .quote-card .quote-text {
        font-size: 17px;
      }
    }
  </style>
</head>
<body>
  <%- include('partials/header', { user }) %>

  <div class="layout-container">
    <div class="sidebar">
      <div class="sidebar-title text-muted small px-3 py-2">
        <%= user.role === 'admin' ? '管理员功能' : '店员功能' %>
      </div>
      <% if (user.role === 'admin') { %>
        <%- include('partials/sidebar-admin', { currentPage }) %>
      <% } else { %>
        <%- include('partials/sidebar-clerk', { currentPage }) %>
      <% } %>
    </div>

    <div class="main-content">
      <!-- 欢迎区域 -->
      <div class="welcome-hero">
        <div class="date-text">
          <%= now.getFullYear() %>年<%= now.getMonth() + 1 %>月<%= now.getDate() %>日
          星期<%= ['日','一','二','三','四','五','六'][now.getDay()] %>
        </div>
        <h2><%= greeting %>，<%= user.name %></h2>
        <p class="mb-0 opacity-75">
          门店：<strong><%= user.store_code %></strong>
          &nbsp;|&nbsp; 角色：<strong><%= user.role === 'admin' ? '管理员' : '店员' %></strong>
        </p>
      </div>

      <!-- 随机语录 -->
      <div class="quote-card">
        <i class="bi bi-quote quote-icon"></i>
        <div class="quote-text">"<%= quote.text %>"</div>
        <div class="quote-from">—— <%= quote.from %></div>
        <% if (source === 'api') { %>
          <div class="quote-source">📡 来自一言网实时语录</div>
        <% } else { %>
          <div class="quote-source">📚 来自本地经典语录库</div>
        <% } %>
      </div>

      <!-- 快捷入口 -->
      <h6 class="text-muted mb-3"><i class="bi bi-star me-1"></i>快捷入口</h6>
      <div class="row g-3">
        <% if (user.role === 'admin') { %>
          <div class="col-6 col-md-4">
            <a href="/admin/users" class="quick-card bg-card-1">
              <div class="card-icon"><i class="bi bi-people"></i></div>
              <div class="card-label">人员管理</div>
            </a>
          </div>
          <div class="col-6 col-md-4">
            <a href="/admin/products" class="quick-card bg-card-2">
              <div class="card-icon"><i class="bi bi-box-seam"></i></div>
              <div class="card-label">商品管理</div>
            </a>
          </div>
          <div class="col-6 col-md-4">
            <a href="/admin/stores" class="quick-card bg-card-3">
              <div class="card-icon"><i class="bi bi-building"></i></div>
              <div class="card-label">门店管理</div>
            </a>
          </div>
          <div class="col-6 col-md-4">
            <a href="/admin/schedules" class="quick-card bg-card-6">
              <div class="card-icon"><i class="bi bi-calendar-check"></i></div>
              <div class="card-label">排班管理</div>
            </a>
          </div>
          <div class="col-6 col-md-4">
            <a href="/admin/reports" class="quick-card bg-card-4">
              <div class="card-icon"><i class="bi bi-bar-chart-line"></i></div>
              <div class="card-label">销售统计报表</div>
            </a>
          </div>
          <div class="col-6 col-md-4">
            <a href="/admin/sales-detail" class="quick-card bg-card-5">
              <div class="card-icon"><i class="bi bi-table"></i></div>
              <div class="card-label">销售明细表</div>
            </a>
          </div>
        <% } else { %>
          <div class="col-6 col-md-4">
            <a href="/clerk/info" class="quick-card bg-card-1">
              <div class="card-icon"><i class="bi bi-person-badge"></i></div>
              <div class="card-label">信息管理</div>
            </a>
          </div>
          <div class="col-6 col-md-4">
            <a href="/clerk/sales-entry" class="quick-card bg-card-2">
              <div class="card-icon"><i class="bi bi-cart-plus"></i></div>
              <div class="card-label">销售录入</div>
            </a>
          </div>
          <div class="col-6 col-md-4">
            <a href="/clerk/sales-query" class="quick-card bg-card-3">
              <div class="card-icon"><i class="bi bi-search"></i></div>
              <div class="card-label">销售数据查询</div>
            </a>
          </div>
          <div class="col-6 col-md-4">
            <a href="/clerk/schedules" class="quick-card bg-card-6">
              <div class="card-icon"><i class="bi bi-calendar-check"></i></div>
              <div class="card-label">门店排班</div>
            </a>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

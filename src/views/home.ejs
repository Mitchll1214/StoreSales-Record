<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>首页 - 门店销售统计系统</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/header', { user }) %>

  <div class="layout-container">
    <div class="sidebar">
      <div class="sidebar-title">
        <%= user.role === 'admin' ? '管理员功能' : '店员功能' %>
      </div>
      <% if (user.role === 'admin') { %>
        <%- include('partials/sidebar-admin', { currentPage }) %>
      <% } else { %>
        <%- include('partials/sidebar-clerk', { currentPage }) %>
      <% } %>
    </div>

    <div class="main-content">
      <!-- 欢迎区域 -->
      <div class="welcome-hero">
        <div class="date-text">
          <%= now.getFullYear() %>年<%= now.getMonth() + 1 %>月<%= now.getDate() %>日
          &nbsp;·&nbsp; 星期<%= ['日','一','二','三','四','五','六'][now.getDay()] %>
        </div>
        <h2><%= greeting %>，<%= user.name %></h2>
        <p class="mb-0 opacity-75" style="font-size:0.9rem;">
          <span>门店：<strong><%= user.store_code %></strong></span>
          <span class="mx-2 opacity-50">|</span>
          <span>角色：<strong><%= user.role === 'admin' ? '管理员' : '店员' %></strong></span>
        </p>
      </div>

      <!-- 随机语录 -->
      <div class="quote-card">
        <i class="bi bi-quote quote-icon"></i>
        <div class="quote-text">"<%= quote.text %>"</div>
        <div class="quote-from">—— <%= quote.from %></div>
        <% if (source === 'api') { %>
          <div class="quote-source">📡 来自一言网实时语录</div>
        <% } else { %>
          <div class="quote-source">📚 来自本地经典语录库</div>
        <% } %>
      </div>

      <!-- 快捷入口 -->
      <h6 class="mb-3 d-flex align-items-center gap-1">
        <i class="bi bi-star-fill" style="color:#f59e0b;font-size:0.7rem;"></i> 快捷入口
      </h6>
      <div class="row g-3">
        <% if (user.role === 'admin') { %>
          <div class="col-6 col-md-4">
            <a href="/admin/users" class="quick-card bg-card-1">
              <div class="card-icon"><i class="bi bi-people"></i></div>
              <div class="card-label">人员管理</div>
            </a>
          </div>
          <div class="col-6 col-md-4">
            <a href="/admin/products" class="quick-card bg-card-2">
              <div class="card-icon"><i class="bi bi-box-seam"></i></div>
              <div class="card-label">商品管理</div>
            </a>
          </div>
          <div class="col-6 col-md-4">
            <a href="/admin/stores" class="quick-card bg-card-3">
              <div class="card-icon"><i class="bi bi-building"></i></div>
              <div class="card-label">门店管理</div>
            </a>
          </div>
          <div class="col-6 col-md-4">
            <a href="/admin/schedules" class="quick-card bg-card-6">
              <div class="card-icon"><i class="bi bi-calendar-check"></i></div>
              <div class="card-label">排班管理</div>
            </a>
          </div>
          <div class="col-6 col-md-4">
            <a href="/admin/reports" class="quick-card bg-card-4">
              <div class="card-icon"><i class="bi bi-bar-chart-line"></i></div>
              <div class="card-label">销售统计报表</div>
            </a>
          </div>
          <div class="col-6 col-md-4">
            <a href="/admin/sales-detail" class="quick-card bg-card-5">
              <div class="card-icon"><i class="bi bi-table"></i></div>
              <div class="card-label">销售明细表</div>
            </a>
          </div>
        <% } else { %>
          <div class="col-6 col-md-4">
            <a href="/clerk/info" class="quick-card bg-card-1">
              <div class="card-icon"><i class="bi bi-person-badge"></i></div>
              <div class="card-label">信息管理</div>
            </a>
          </div>
          <div class="col-6 col-md-4">
            <a href="/clerk/sales-entry" class="quick-card bg-card-2">
              <div class="card-icon"><i class="bi bi-cart-plus"></i></div>
              <div class="card-label">销售录入</div>
            </a>
          </div>
          <div class="col-6 col-md-4">
            <a href="/clerk/sales-query" class="quick-card bg-card-3">
              <div class="card-icon"><i class="bi bi-search"></i></div>
              <div class="card-label">销售数据查询</div>
            </a>
          </div>
          <div class="col-6 col-md-4">
            <a href="/clerk/schedules" class="quick-card bg-card-6">
              <div class="card-icon"><i class="bi bi-calendar-check"></i></div>
              <div class="card-label">门店排班</div>
            </a>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

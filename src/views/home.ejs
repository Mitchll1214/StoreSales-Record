<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>首页 - 门店销售统计系统</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/header', { user }) %>

  <div class="layout-container">
    <div class="sidebar">
      <div class="sidebar-title"><%= user.role === 'admin' ? '管理员功能' : '店员功能' %></div>
      <% if (user.role === 'admin') { %>
        <%- include('partials/sidebar-admin', { currentPage }) %>
      <% } else { %>
        <%- include('partials/sidebar-clerk', { currentPage }) %>
      <% } %>
    </div>

    <div class="main-content">
      <div class="welcome-hero">
        <div class="date-text">
          <%= now.getFullYear() %>年<%= now.getMonth() + 1 %>月<%= now.getDate() %>日
          &nbsp;·&nbsp; 星期<%= ['日','一','二','三','四','五','六'][now.getDay()] %>
        </div>
        <h2><%= greeting %>，<%= user.name %></h2>
        <p class="mb-0 opacity-75" style="font-size:0.9rem;">
          <span>门店：<strong><%= user.store_code %></strong></span>
          <span class="mx-2 opacity-50">|</span>
          <span>角色：<strong><%= user.role === 'admin' ? '管理员' : '店员' %></strong></span>
        </p>
      </div>

      <div class="quote-card">
        <i class="bi bi-quote quote-icon"></i>
        <div class="quote-text">"<%= quote.text %>"</div>
        <div class="quote-from">—— <%= quote.from %></div>
        <% if (source === 'api') { %>
          <div class="quote-source">📡 来自一言网实时语录</div>
        <% } else { %>
          <div class="quote-source">📚 来自本地经典语录库</div>
        <% } %>
      </div>

      <h6 class="mb-3 d-flex align-items-center gap-1">
        <i class="bi bi-star-fill" style="color:var(--amber);font-size:0.72rem;"></i> 快捷入口
        <span class="text-muted fw-normal small ms-2">在每个页面标题右侧点击 <i class="bi bi-bookmark-plus"></i> 收藏常用菜单</span>
      </h6>
      <div class="row g-3" id="quickLinks"></div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // 菜单映射: page_key → { label, icon, url, color }
    var menuMap = {};
    <% if (user.role === 'admin') { %>
      menuMap = {
        'users':           { label:'人员管理',   icon:'bi-people',         url:'/admin/users',          color:'bg-card-1' },
        'products':        { label:'商品管理',   icon:'bi-box-seam',       url:'/admin/products',       color:'bg-card-2' },
        'stores':          { label:'门店管理',   icon:'bi-building',       url:'/admin/stores',         color:'bg-card-3' },
        'schedules':       { label:'排班管理',   icon:'bi-calendar-check', url:'/admin/schedules',      color:'bg-card-6' },
        'reports':         { label:'销售统计报表', icon:'bi-bar-chart-line', url:'/admin/reports',       color:'bg-card-4' },
        'sales-detail':    { label:'销售明细表', icon:'bi-table',          url:'/admin/sales-detail',   color:'bg-card-5' },
        'inventory':       { label:'库存报表',   icon:'bi-boxes',          url:'/admin/inventory',      color:'bg-card-1' },
        'operation-logs':  { label:'操作日志',   icon:'bi-journal-text',   url:'/admin/operation-logs', color:'bg-card-3' },
      };
    <% } else { %>
      menuMap = {
        'info':         { label:'信息管理',     icon:'bi-person-badge',   url:'/clerk/info',        color:'bg-card-1' },
        'sales-entry':  { label:'销售录入',     icon:'bi-cart-plus',      url:'/clerk/sales-entry',  color:'bg-card-2' },
        'sales-query':  { label:'销售数据查询', icon:'bi-search',         url:'/clerk/sales-query',  color:'bg-card-3' },
        'schedules':    { label:'门店排班',     icon:'bi-calendar-check', url:'/clerk/schedules',    color:'bg-card-6' },
        'inventory':    { label:'库存上报',     icon:'bi-boxes',          url:'/clerk/inventory',    color:'bg-card-4' },
      };
    <% } %>

    // 服务端渲染的收藏列表
    var favKeys = <%- JSON.stringify(favKeys || []) %>;

    function renderQuickLinks() {
      var container = document.getElementById('quickLinks');
      if (!favKeys.length) {
        container.innerHTML = '<div class="col-12 text-muted small py-3">还没有收藏，去侧边栏点 <i class="bi bi-star"></i> 收藏常用菜单吧</div>';
        return;
      }
      container.innerHTML = favKeys.map(function(key) {
        var m = menuMap[key];
        if (!m) return '';
        return '<div class="col-6 col-md-4"><a href="' + m.url + '" class="quick-card ' + m.color + '">' +
          '<div class="card-icon"><i class="bi ' + m.icon + '"></i></div>' +
          '<div class="card-label">' + m.label + '</div></a></div>';
      }).join('');
    }

    renderQuickLinks();

    // 监听来自侧边栏的收藏变化事件，实时刷新
    window.addEventListener('storage', function() { renderQuickLinks(); });
  </script>
</body>
</html>

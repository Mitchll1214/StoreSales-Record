<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>门店排班 - 门店销售统计系统</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <style>
    .calendar-wrap {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 2px 16px rgba(0,0,0,0.06);
      overflow: hidden;
    }
    .calendar-toolbar {
      display: flex; align-items: center; justify-content: center;
      padding: 14px 20px;
      background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
      color: #fff;
    }
    .calendar-toolbar .month-title {
      font-size: 1.15rem; font-weight: 700; letter-spacing: 1px;
      min-width: 160px; text-align: center;
    }
    .calendar-toolbar .btn-month {
      background: rgba(255,255,255,.15); border: none; color: #fff;
      width: 34px; height: 34px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      transition: background .2s;
    }
    .calendar-toolbar .btn-month:hover { background: rgba(255,255,255,.3); color: #fff; }
    .calendar-toolbar .btn-today {
      background: rgba(255,255,255,.25); border: none; color: #fff;
      border-radius: 20px; padding: 4px 16px; font-size: .85rem;
      transition: background .2s;
    }
    .calendar-toolbar .btn-today:hover { background: rgba(255,255,255,.4); color: #fff; }

    .calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); }
    .calendar-day-header {
      text-align: center; font-weight: 700; font-size: .8rem;
      padding: 10px 0; background: #f1f3f9; color: #7c8097;
      border-bottom: 1px solid #e8ecf1;
    }
    .calendar-day-header.weekend { color: #e0535e; }

    .calendar-cell {
      min-height: 88px; padding: 5px 6px;
      border-right: 1px solid #eef0f5; border-bottom: 1px solid #eef0f5;
      background: #fff; transition: all .15s;
      overflow: hidden; position: relative;
    }
    .calendar-cell:nth-child(7n) { border-right: none; }
    .calendar-cell.other-month { background: #fafbfc; color: #c0c4d0; }
    .calendar-cell.today {
      background: linear-gradient(180deg, #e6f9f0 0%, #fff 30%);
      box-shadow: inset 0 2px 0 #43e97b;
    }
    .calendar-cell .day-num {
      font-size: .9rem; font-weight: 700; margin-bottom: 3px; line-height: 1.2;
    }
    .calendar-cell .day-num.weekend { color: #e0535e; }
    .calendar-cell .day-num.today-num {
      display: inline-flex; align-items: center; justify-content: center;
      width: 26px; height: 26px; border-radius: 50%;
      background: #43e97b; color: #fff; font-size: .8rem;
    }
    .calendar-cell .staff-tag {
      display: inline-block; font-size: .68rem; font-weight: 500;
      border-radius: 10px; padding: 1px 7px; margin: 1px 1px;
      max-width: 100%; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      line-height: 1.5;
    }
    .calendar-cell .staff-tag:nth-child(4n+1) { background: #e8f0fe; color: #1967d2; }
    .calendar-cell .staff-tag:nth-child(4n+2) { background: #fce8e6; color: #c5221f; }
    .calendar-cell .staff-tag:nth-child(4n+3) { background: #e6f4ea; color: #137333; }
    .calendar-cell .staff-tag:nth-child(4n+4) { background: #fef7e0; color: #b06000; }
    .calendar-cell .staff-tag.more-tag {
      background: #5f6368; color: #fff;
    }
    .no-schedule { color: #c0c4d0; font-size: .7rem; text-align: center; margin-top: 20px; }
  </style>
</head>
<body>
  <%- include('../partials/header', { user }) %>

  <div class="layout-container">
    <div class="sidebar">
      <div class="sidebar-title text-muted small px-3 py-2">店员功能</div>
      <%- include('../partials/sidebar-clerk', { currentPage }) %>
    </div>

    <div class="main-content">
      <h4 class="mb-3"><i class="bi bi-calendar-check me-2"></i><%= title %>
        <small class="text-muted fs-6">(<%= user.store_code %>)</small>
      </h4>

      <div class="calendar-wrap" style="min-height:400px;">
        <div id="calendarContent">
          <div class="text-center py-5"><div class="spinner-border text-success"></div></div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let currentYear, currentMonth;

    document.addEventListener('DOMContentLoaded', () => {
      const now = new Date();
      currentYear = now.getFullYear();
      currentMonth = now.getMonth() + 1;
      renderCalendar();
    });

    function changeMonth(delta) {
      currentMonth += delta;
      if (currentMonth < 1) { currentMonth = 12; currentYear--; }
      if (currentMonth > 12) { currentMonth = 1; currentYear++; }
      renderCalendar();
    }

    function goToday() {
      const now = new Date();
      currentYear = now.getFullYear();
      currentMonth = now.getMonth() + 1;
      renderCalendar();
    }

    async function renderCalendar() {
      document.getElementById('calendarContent').innerHTML =
        '<div class="text-center py-5"><div class="spinner-border text-success"></div></div>';

      const firstDay = new Date(currentYear, currentMonth - 1, 1);
      const lastDay = new Date(currentYear, currentMonth, 0);
      const startDate = firstDay.toISOString().slice(0, 10);
      const endDate = lastDay.toISOString().slice(0, 10);

      try {
        const res = await fetch(`/api/clerk/schedules?start_date=${startDate}&end_date=${endDate}`);
        const result = await res.json();
        const data = result.data || [];

        // 构建按日期分组的人员名单
        const dateMap = {};
        data.forEach(s => {
          if (!dateMap[s.schedule_date]) dateMap[s.schedule_date] = [];
          dateMap[s.schedule_date].push(s.user_name);
        });

        buildCalendarHTML(firstDay, lastDay, dateMap);
      } catch (err) {
        document.getElementById('calendarContent').innerHTML =
          '<div class="alert alert-danger m-3">加载排班数据失败</div>';
      }
    }

    function buildCalendarHTML(firstDay, lastDay, dateMap) {
      const today = new Date().toISOString().slice(0, 10);
      const startDayOfWeek = firstDay.getDay();
      const dayHeaders = ['日', '一', '二', '三', '四', '五', '六'];

      // 工具栏
      let html = '<div class="calendar-toolbar">';
      html += `<button class="btn-month" onclick="changeMonth(-1)"><i class="bi bi-chevron-left"></i></button>`;
      html += `<span class="month-title">${currentYear}年 ${currentMonth}月</span>`;
      html += `<button class="btn-month" onclick="changeMonth(1)"><i class="bi bi-chevron-right"></i></button>`;
      html += `<button class="btn-today ms-3" onclick="goToday()"><i class="bi bi-calendar-week me-1"></i>本月</button>`;
      html += '</div>';

      // 星期头
      html += '<div class="calendar-grid">';
      dayHeaders.forEach((d, i) => {
        const cls = (i === 0 || i === 6) ? 'calendar-day-header weekend' : 'calendar-day-header';
        html += `<div class="${cls}">${d}</div>`;
      });
      html += '</div>';

      // 日期格子
      html += '<div class="calendar-grid">';
      for (let i = 0; i < startDayOfWeek; i++) {
        html += '<div class="calendar-cell other-month"></div>';
      }

      for (let d = 1; d <= lastDay.getDate(); d++) {
        const dateStr = `${currentYear}-${String(currentMonth).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
        const dayOfWeek = new Date(currentYear, currentMonth - 1, d).getDay();
        const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;
        const isToday = dateStr === today;
        const names = dateMap[dateStr] || [];

        let cls = 'calendar-cell';
        if (isToday) cls += ' today';

        let dayHtml = isToday
          ? `<span class="day-num today-num">${d}</span>`
          : `<span class="day-num${isWeekend ? ' weekend' : ''}">${d}</span>`;

        let tagsHtml = '';
        const maxShow = 3;
        names.slice(0, maxShow).forEach(name => {
          tagsHtml += `<span class="staff-tag">${name}</span>`;
        });
        if (names.length > maxShow) {
          tagsHtml += `<span class="staff-tag more-tag">+${names.length - maxShow}</span>`;
        }
        if (names.length === 0) {
          tagsHtml += '<div class="no-schedule">—</div>';
        }

        html += `<div class="${cls}">${dayHtml}${tagsHtml}</div>`;
      }

      const totalCells = startDayOfWeek + lastDay.getDate();
      const remaining = (7 - (totalCells % 7)) % 7;
      for (let i = 0; i < remaining; i++) {
        html += '<div class="calendar-cell other-month"></div>';
      }

      html += '</div>';
      document.getElementById('calendarContent').innerHTML = html;
    }
  </script>
</body>
</html>

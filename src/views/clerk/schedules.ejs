<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>门店排班 - 门店销售统计系统</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/header', { user }) %>

  <div class="layout-container">
    <div class="sidebar">
      <div class="sidebar-title">店员功能</div>
      <%- include('../partials/sidebar-clerk', { currentPage }) %>
    </div>

    <div class="main-content">
      <h4 class="mb-3"><i class="bi bi-calendar-check me-2"></i><%= title %>
        <small class="text-secondary fs-6">(<%= user.store_code %>)</small>
      </h4>

      <div class="calendar-wrap" style="min-height:400px;">
        <div id="calendarContent">
          <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let currentYear, currentMonth;

    document.addEventListener('DOMContentLoaded', () => {
      const now = new Date();
      currentYear = now.getFullYear();
      currentMonth = now.getMonth() + 1;
      renderCalendar();
    });

    function changeMonth(delta) {
      currentMonth += delta;
      if (currentMonth < 1) { currentMonth = 12; currentYear--; }
      if (currentMonth > 12) { currentMonth = 1; currentYear++; }
      renderCalendar();
    }

    function goToday() {
      const now = new Date();
      currentYear = now.getFullYear();
      currentMonth = now.getMonth() + 1;
      renderCalendar();
    }

    async function renderCalendar() {
      document.getElementById('calendarContent').innerHTML =
        '<div class="text-center py-5"><div class="spinner-border text-primary"></div></div>';

      const firstDay = new Date(currentYear, currentMonth - 1, 1);
      const lastDay = new Date(currentYear, currentMonth, 0);
      const startDate = firstDay.toISOString().slice(0, 10);
      const endDate = lastDay.toISOString().slice(0, 10);

      try {
        const res = await fetch(`/api/clerk/schedules?start_date=${startDate}&end_date=${endDate}`);
        const result = await res.json();
        const data = result.data || [];

        const dateMap = {};
        data.forEach(s => {
          if (!dateMap[s.schedule_date]) dateMap[s.schedule_date] = [];
          dateMap[s.schedule_date].push(s.user_name);
        });

        buildCalendarHTML(firstDay, lastDay, dateMap);
      } catch (err) {
        document.getElementById('calendarContent').innerHTML =
          '<div class="alert alert-danger m-3">加载排班数据失败</div>';
      }
    }

    function buildCalendarHTML(firstDay, lastDay, dateMap) {
      const today = new Date().toISOString().slice(0, 10);
      const startDayOfWeek = firstDay.getDay();
      const dayHeaders = ['日', '一', '二', '三', '四', '五', '六'];

      let html = '<div class="calendar-toolbar">';
      html += `<button class="btn-month" onclick="changeMonth(-1)"><i class="bi bi-chevron-left"></i></button>`;
      html += `<span class="month-title">${currentYear}年 ${currentMonth}月</span>`;
      html += `<button class="btn-month" onclick="changeMonth(1)"><i class="bi bi-chevron-right"></i></button>`;
      html += `<button class="btn-today ms-3" onclick="goToday()"><i class="bi bi-calendar-week me-1"></i>本月</button>`;
      html += '</div>';

      html += '<div class="calendar-grid">';
      dayHeaders.forEach((d, i) => {
        const cls = (i === 0 || i === 6) ? 'calendar-day-header weekend' : 'calendar-day-header';
        html += `<div class="${cls}">${d}</div>`;
      });
      html += '</div>';

      html += '<div class="calendar-grid">';
      for (let i = 0; i < startDayOfWeek; i++) {
        html += '<div class="calendar-cell other-month"></div>';
      }

      for (let d = 1; d <= lastDay.getDate(); d++) {
        const dateStr = `${currentYear}-${String(currentMonth).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
        const dayOfWeek = new Date(currentYear, currentMonth - 1, d).getDay();
        const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;
        const isToday = dateStr === today;
        const names = dateMap[dateStr] || [];

        let cls = 'calendar-cell';
        if (isToday) cls += ' today';

        let dayHtml = isToday
          ? `<span class="day-num today-num">${d}</span>`
          : `<span class="day-num${isWeekend ? ' weekend' : ''}">${d}</span>`;

        let tagsHtml = '';
        const maxShow = 3;
        names.slice(0, maxShow).forEach(name => {
          tagsHtml += `<span class="staff-tag">${name}</span>`;
        });
        if (names.length > maxShow) {
          tagsHtml += `<span class="staff-tag more-tag">+${names.length - maxShow}</span>`;
        }
        if (names.length === 0) {
          tagsHtml += '<div class="no-schedule">&mdash;</div>';
        }

        html += `<div class="${cls}">${dayHtml}${tagsHtml}</div>`;
      }

      const totalCells = startDayOfWeek + lastDay.getDate();
      const remaining = (7 - (totalCells % 7)) % 7;
      for (let i = 0; i < remaining; i++) {
        html += '<div class="calendar-cell other-month"></div>';
      }

      html += '</div>';
      document.getElementById('calendarContent').innerHTML = html;
    }
  </script>
</body>
</html>

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>销售数据查询 - 门店销售统计系统</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/header', { user }) %>

  <div class="layout-container">
    <div class="sidebar">
      <div class="sidebar-title text-muted small px-3 py-2">店员功能</div>
      <%- include('../partials/sidebar-clerk', { currentPage }) %>
    </div>

    <div class="main-content">
      <h4 class="mb-4"><i class="bi bi-search me-2"></i><%= title %></h4>

      <!-- 筛选条件 -->
      <div class="card shadow-sm mb-3">
        <div class="card-body">
          <div class="row g-3 align-items-end">
            <div class="col-md-3">
              <label class="form-label">筛选商品</label>
              <select class="form-select" id="filterProduct">
                <option value="">全部商品</option>
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label">开始日期</label>
              <input type="date" class="form-control" id="filterStartDate">
            </div>
            <div class="col-md-3">
              <label class="form-label">结束日期</label>
              <input type="date" class="form-control" id="filterEndDate">
            </div>
            <div class="col-md-3">
              <button class="btn btn-primary w-100" onclick="loadData(1)">
                <i class="bi bi-search"></i> 查询
              </button>
            </div>
          </div>
          <div class="form-text mt-2">默认查询最近30天数据，最多可查询前推60天</div>
        </div>
      </div>

      <!-- 查询结果 -->
      <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <h5 class="mb-0">销售记录明细</h5>
          <span class="text-muted small" id="totalInfo"></span>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>门店编码</th>
                  <th>销售日期</th>
                  <th>销售人员</th>
                  <th>商品名称</th>
                  <th>销售数量</th>
                  <th>登记时间</th>
                </tr>
              </thead>
              <tbody id="tableBody">
                <tr><td colspan="6" class="text-center text-muted py-4">点击查询按钮加载数据</td></tr>
              </tbody>
            </table>
          </div>
        </div>
        <div class="card-footer bg-white">
          <nav id="pagination"></nav>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // 日期格式化：直接从 ISO 字符串截取，不经过时区转换
    function fmtDate(isoStr) {
      if (!isoStr) return '-';
      return isoStr.replace('T', ' ').slice(0, 19);
    }
    const pageSize = 10;
    let currentPage = 1;

    // 初始化日期：默认最近30天
    (function initDates() {
      const now = new Date();
      const thirtyDaysAgo = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);
      document.getElementById('filterEndDate').value = now.toISOString().slice(0, 10);
      document.getElementById('filterStartDate').value = thirtyDaysAgo.toISOString().slice(0, 10);
    })();

    // 加载商品下拉
    async function loadProducts() {
      try {
        const res = await fetch('/api/clerk/store-products');
        const products = await res.json();
        const sel = document.getElementById('filterProduct');
        products.forEach(p => {
          sel.innerHTML += `<option value="${p.id}">${p.product_name}</option>`;
        });
      } catch (err) { /* 加载失败不影响主要功能 */ }
    }
    loadProducts();

    async function loadData(page) {
      currentPage = page || 1;
      const params = new URLSearchParams();
      const productId = document.getElementById('filterProduct').value;
      const startDate = document.getElementById('filterStartDate').value;
      const endDate = document.getElementById('filterEndDate').value;

      if (productId) params.set('product_id', productId);
      if (startDate) params.set('start_date', startDate + 'T00:00:00');
      if (endDate) params.set('end_date', endDate + 'T23:59:59');
      params.set('page', currentPage);
      params.set('page_size', pageSize);

      try {
        const res = await fetch(`/api/clerk/sales?${params.toString()}`);
        const result = await res.json();

        document.getElementById('totalInfo').textContent = `共 ${result.total} 条记录`;

        const tbody = document.getElementById('tableBody');
        if (result.data.length === 0) {
          tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">暂无数据</td></tr>';
        } else {
          tbody.innerHTML = result.data.map(r => `
            <tr>
              <td>${r.store_code}</td>
              <td>${fmtDate(r.sale_date)}</td>
              <td>${r.sales_person_name}</td>
              <td>${r.product_name}</td>
              <td><span class="badge bg-primary">${r.quantity}</span></td>
              <td>${fmtDate(r.recorded_at)}</td>
            </tr>
          `).join('');
        }

        // 分页
        renderPagination(result.total_pages, currentPage);
      } catch (err) {
        document.getElementById('tableBody').innerHTML =
          '<tr><td colspan="6" class="text-center text-danger py-4">加载失败</td></tr>';
      }
    }

    function renderPagination(totalPages, current) {
      const nav = document.getElementById('pagination');
      if (totalPages <= 1) { nav.innerHTML = ''; return; }

      let html = '<ul class="pagination pagination-sm justify-content-center mb-0">';
      html += `<li class="page-item ${current === 1 ? 'disabled' : ''}">
        <a class="page-link" href="#" onclick="loadData(${current - 1});return false">上一页</a></li>`;
      for (let i = 1; i <= totalPages; i++) {
        html += `<li class="page-item ${i === current ? 'active' : ''}">
          <a class="page-link" href="#" onclick="loadData(${i});return false">${i}</a></li>`;
      }
      html += `<li class="page-item ${current === totalPages ? 'disabled' : ''}">
        <a class="page-link" href="#" onclick="loadData(${current + 1});return false">下一页</a></li>`;
      html += '</ul>';
      nav.innerHTML = html;
    }

    // 初始加载
    loadData(1);
  </script>
</body>
</html>

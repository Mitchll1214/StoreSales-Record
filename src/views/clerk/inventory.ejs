<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>库存上报 - 门店销售统计系统</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/header', { user }) %>
  <div class="layout-container">
    <div class="sidebar">
      <div class="sidebar-title">店员功能</div>
      <%- include('../partials/sidebar-clerk', { currentPage }) %>
    </div>
    <div class="main-content">
      <h4 class="mb-3"><i class="bi bi-boxes me-2"></i><%= title %></h4>
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex align-items-center gap-2">
          <label class="form-label mb-0">上报日期：</label>
          <input type="date" class="form-control form-control-sm" id="reportDate" style="width:150px">
        </div>
        <button class="btn btn-primary" onclick="submitInventory()"><i class="bi bi-check-lg"></i> 提交库存</button>
      </div>

      <div class="card shadow-sm">
        <div class="card-body p-0">
          <div id="msgBox" class="px-3 pt-3"></div>
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr><th>商品条码</th><th>商品名称</th><th>历史库存数</th><th style="width:120px">库存数量</th><th>上次提交时间</th></tr>
              </thead>
              <tbody id="tableBody">
                <tr><td colspan="5" class="text-center text-muted py-4">加载中...</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function fmtDate(v) {
      if (!v) return '';
      var d = new Date(v);
      return d.getFullYear() + '-' + ('0'+(d.getMonth()+1)).slice(-2) + '-' + ('0'+d.getDate()).slice(-2)
        + ' ' + ('0'+d.getHours()).slice(-2) + ':' + ('0'+d.getMinutes()).slice(-2);
    }

    var today = new Date().toISOString().slice(0, 10);
    var sevenDaysAgo = new Date(Date.now() - 7 * 86400000).toISOString().slice(0, 10);
    document.getElementById('reportDate').value = today;
    document.getElementById('reportDate').setAttribute('min', sevenDaysAgo);
    document.getElementById('reportDate').setAttribute('max', today);

    var products = [];
    var existingMap = {};

    async function loadData() {
      try {
        var res = await fetch('/api/clerk/store-products');
        products = await res.json();
        if (!products.length) {
          document.getElementById('tableBody').innerHTML =
            '<tr><td colspan="5" class="text-center text-muted py-4">暂无负责商品</td></tr>';
          return;
        }
        await loadExisting();
        renderTable();
      } catch (e) {
        document.getElementById('tableBody').innerHTML =
          '<tr><td colspan="5" class="text-center text-danger py-4">加载失败</td></tr>';
      }
    }

    async function loadExisting() {
      var date = document.getElementById('reportDate').value;
      try {
        var invRes = await fetch('/api/clerk/inventory?date=' + date);
        existingMap = await invRes.json();
      } catch (e) { existingMap = {}; }
    }

    document.getElementById('reportDate').addEventListener('change', async function() {
      await loadExisting();
      renderTable();
    });

    function renderTable() {
      document.getElementById('tableBody').innerHTML = products.map(function(p) {
        var rec = existingMap[p.id];
        var qty = rec ? rec.qty : '';
        var time = rec && rec.time ? fmtDate(rec.time) : '';
        return '<tr><td><code>' + p.product_code + '</code></td>' +
          '<td>' + p.product_name + '</td>' +
          '<td class="text-muted">' + (rec ? '<span class="badge bg-secondary">' + qty + '</span>' : '-') + '</td>' +
          '<td><input type="number" class="form-control form-control-sm inv-qty" min="0" ' +
          'value="" data-pid="' + p.id + '" placeholder="输入库存数" style="width:100px"></td>' +
          '<td class="text-muted small">' + (time || '-') + '</td></tr>';
      }).join('');
    }

    async function submitInventory() {
      var items = [];
      document.querySelectorAll('.inv-qty').forEach(function(input) {
        var pid = parseInt(input.dataset.pid);
        var val = input.value.trim();
        if (val !== '') items.push({ product_id: pid, quantity: parseInt(val) || 0 });
      });

      if (items.length === 0) {
        document.getElementById('msgBox').innerHTML = '<div class="alert alert-warning">请至少填写一条库存数据</div>';
        return;
      }

      var date = document.getElementById('reportDate').value;
      try {
        var res = await fetch('/api/clerk/inventory', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: items, date: date }),
        });
        var data = await res.json();
        if (data.success) {
          document.getElementById('msgBox').innerHTML =
            '<div class="alert alert-success d-flex align-items-center"><i class="bi bi-check-circle-fill me-2 fs-5"></i><strong>库存上报成功！</strong></div>';
          await loadExisting();
          renderTable();
          setTimeout(function() { document.getElementById('msgBox').innerHTML = ''; }, 3000);
        } else {
          document.getElementById('msgBox').innerHTML = '<div class="alert alert-danger">' + (data.error || '上报失败') + '</div>';
        }
      } catch (e) {
        document.getElementById('msgBox').innerHTML = '<div class="alert alert-danger">提交失败，请重试</div>';
      }
    }

    loadData();
  </script>
</body>
</html>

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>销售录入 - 门店销售统计系统</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/header', { user }) %>

  <div class="layout-container">
    <div class="sidebar">
      <div class="sidebar-title text-muted small px-3 py-2">店员功能</div>
      <%- include('../partials/sidebar-clerk', { currentPage }) %>
    </div>

    <div class="main-content">
      <h4 class="mb-4"><i class="bi bi-cart-plus me-2"></i><%= title %></h4>

      <div class="card shadow-sm">
        <div class="card-header bg-white">
          <h5 class="mb-0">提交销售记录</h5>
        </div>
        <div class="card-body">
          <div id="msgBox"></div>

          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">销售日期 <span class="text-danger">*</span></label>
              <input type="datetime-local" class="form-control" id="saleDate">
              <div class="form-text">默认为当前日期时间，可修改（精确到小时）</div>
            </div>
            <div class="col-md-6">
              <label class="form-label">销售门店</label>
              <input type="text" class="form-control" value="<%= user.store_code %>" readonly disabled>
              <div class="form-text">默认归属门店，不可修改</div>
            </div>
            <div class="col-md-6">
              <label class="form-label">销售商品 <span class="text-danger">*</span></label>
              <select class="form-select" id="productId">
                <option value="">-- 请选择商品 --</option>
                <% products.forEach(function(p) { %>
                  <option value="<%= p.id %>"><%= p.product_name %> (<%= p.product_code %>)</option>
                <% }); %>
              </select>
              <div class="form-text">仅显示本人负责的商品</div>
            </div>
            <div class="col-md-6">
              <label class="form-label">销售数量 <span class="text-danger">*</span></label>
              <input type="number" class="form-control" id="quantity" min="1" step="1" placeholder="请输入正整数">
            </div>
            <div class="col-12">
              <button class="btn btn-primary btn-lg" onclick="submitSale()">
                <i class="bi bi-check-lg"></i> 提交销售记录
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // 默认日期为当前日期时间（精确到小时）
    const now = new Date();
    const localDatetime = new Date(now.getTime() - now.getTimezoneOffset() * 60000)
      .toISOString().slice(0, 16);
    document.getElementById('saleDate').value = localDatetime;

    async function submitSale() {
      const productId = document.getElementById('productId').value;
      const quantity = document.getElementById('quantity').value;
      const saleDate = document.getElementById('saleDate').value;
      const msgBox = document.getElementById('msgBox');

      if (!productId) {
        msgBox.innerHTML = '<div class="alert alert-warning">请选择商品</div>';
        return;
      }
      if (!quantity || parseInt(quantity) <= 0) {
        msgBox.innerHTML = '<div class="alert alert-warning">销售数量必须为正整数</div>';
        return;
      }

      try {
        const res = await fetch('/api/clerk/sales', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            product_id: parseInt(productId),
            quantity: parseInt(quantity),
            sale_date: saleDate,
          }),
        });
        const data = await res.json();
        if (data.success) {
          msgBox.innerHTML = '<div class="alert alert-success"><i class="bi bi-check-circle"></i> 销售记录提交成功！</div>';
          document.getElementById('quantity').value = '';
        } else {
          msgBox.innerHTML = `<div class="alert alert-danger">${data.error}</div>`;
        }
      } catch (err) {
        msgBox.innerHTML = '<div class="alert alert-danger">提交失败，请重试</div>';
      }
    }
  </script>
</body>
</html>
